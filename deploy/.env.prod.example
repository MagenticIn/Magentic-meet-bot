APP_DOMAIN=meetnotes.yourcompany.com

# Dashboard HTTP auth (recommended for internal org rollout)
DASHBOARD_USER=orguser
# Generate with:
# docker run --rm caddy:2.8-alpine caddy hash-password --plaintext "strong-password"
DASHBOARD_PASS_HASH=$2a$14$replace_with_caddy_hash

# Google account for bot
GOOGLE_EMAIL=your-bot-account@yourcompany.com
GOOGLE_PASSWORD=your-google-app-password

# AI / diarization keys
OPENAI_API_KEY=sk-proj-xxxxxxxx
HF_TOKEN=hf_xxxxxxxxxxxxx

# PM integration (optional)
PM_API_BASE_URL=
PM_API_KEY=

# DB
POSTGRES_USER=meetbot
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=meetbot

# Pipeline tuning
WHISPER_MODEL_SIZE=large-v3-turbo
# For Hindi-heavy org calls, set hi
WHISPER_LANGUAGE=hi
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Bot tuning
BOT_DISPLAY_NAME=Magentic Notetaker
BOT_JOIN_TIMEOUT_SEC=120
BOT_MAX_MEETING_DURATION_SEC=7200
BOT_END_DETECTION_STABLE_POLLS=2
