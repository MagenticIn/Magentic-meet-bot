# ──────────────────────────────────────────────
# Magentic-meetbot  —  Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in every value.
#   cp .env.example .env

# ── Google Account (for Meet login) ──────────
GOOGLE_EMAIL=your-bot-account@gmail.com
GOOGLE_PASSWORD=your-app-password

# ── Hugging Face (speaker diarization — only if TRANSCRIPTION_BACKEND=whisper) ─
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Transcription: openai (default) = gpt-4o-transcribe-diarize one API call;
#    whisper = faster-whisper + whisperx/pyannote (needs HF_TOKEN)
TRANSCRIPTION_BACKEND=openai
# OpenAI STT: leave empty for Hindi + English in the same call (auto). Set hi or en only to bias the whole file.
OPENAI_TRANSCRIPTION_LANGUAGE=

# ── OpenAI (transcription when backend=openai, plus summarisation) ─
# Get from platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx

# ── Project-Management API integration ───────
PM_API_BASE_URL=https://pm.example.com/api/v1
PM_API_KEY=pm-key-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── PostgreSQL ───────────────────────────────
POSTGRES_URL=postgresql+asyncpg://meetbot:meetbot@postgres:5432/meetbot
POSTGRES_USER=meetbot
POSTGRES_PASSWORD=meetbot
POSTGRES_DB=meetbot

# ── Redis (task queue) ───────────────────────
REDIS_URL=redis://redis:6379/0

# ── Shared volume for audio/artifacts ────────
SHARED_DATA_DIR=/data

# ── faster-whisper model config (TRANSCRIPTION_BACKEND=whisper only) ─
WHISPER_MODEL_SIZE=large-v3
WHISPER_LANGUAGE=
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── Bot behaviour ────────────────────────────
BOT_DISPLAY_NAME=Magentic Notetaker
BOT_JOIN_TIMEOUT_SEC=120
BOT_MAX_MEETING_DURATION_SEC=7200
